# ============================================================================
# openclaw-memory-rebac — Environment Variables
# ============================================================================
#
# Copy this file to .env and customize for your environment.
#
# Usage:
#   - Plugin config: these vars can be referenced in openclaw.json via ${VAR}
#   - CLI: bin/rebac-mem.ts reads these vars to configure clients
#   - E2E tests: e2e.test.ts uses these to connect to live services
#
# To run E2E tests:
#   1. Start your backend stack: docker compose -f docker/graphiti/docker-compose.yml up
#   2. Copy this file: cp .env.example .env
#   3. Customize if needed (defaults work for docker-compose stack)
#   4. Run: OPENCLAW_LIVE_TEST=1 npm run test:e2e

# ============================================================================
# E2E Test Control
# ============================================================================

# Set to "1" to enable E2E tests (otherwise they're skipped)
OPENCLAW_LIVE_TEST=1

# ============================================================================
# Backend Selection
# ============================================================================

# Backend to use (currently only "graphiti" is supported)
REBAC_MEM_BACKEND=graphiti

# ============================================================================
# SpiceDB Configuration
# ============================================================================

# SpiceDB gRPC endpoint
SPICEDB_ENDPOINT=localhost:50051

# SpiceDB pre-shared key (must match what SpiceDB was started with)
SPICEDB_TOKEN=dev_token

# ============================================================================
# Graphiti Backend Configuration
# ============================================================================

# Graphiti MCP server HTTP endpoint
GRAPHITI_ENDPOINT=http://localhost:8000

# Default group ID for memory isolation
REBAC_MEM_DEFAULT_GROUP_ID=main

# ============================================================================
# Subject Configuration (for CLI and tests)
# ============================================================================

# SpiceDB subject type: "agent" or "person"
REBAC_MEM_SUBJECT_TYPE=agent

# SpiceDB subject ID
REBAC_MEM_SUBJECT_ID=test-agent

# ============================================================================
# Plugin Configuration (referenced in ~/.openclaw/openclaw.json)
# ============================================================================

# Example plugin config referencing these vars:
# {
#   "plugins": {
#     "entries": {
#       "openclaw-memory-rebac": {
#         "enabled": true,
#         "config": {
#           "backend": "graphiti",
#           "spicedb": {
#             "endpoint": "localhost:50051",
#             "token": "${SPICEDB_TOKEN}",
#             "insecure": true
#           },
#           "graphiti": {
#             "endpoint": "${GRAPHITI_ENDPOINT}",
#             "defaultGroupId": "${REBAC_MEM_DEFAULT_GROUP_ID}"
#           },
#           "subjectId": "${REBAC_MEM_SUBJECT_ID}"
#         }
#       }
#     }
#   }
# }
